{
  "extends": "./tsconfig.json",
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts"],
  "compilerOptions": {
    "noEmit": false,
    "rootDir": "./src",
    "outDir": "./out",
    "allowImportingTsExtensions": false,
    "rewriteRelativeImportExtensions": true
  }
}
